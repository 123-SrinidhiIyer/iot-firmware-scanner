# Extracted firmware filesystems (large, regenerated by running the tool)
extractor/extracted_output/

# Uploaded firmware files (via dashboard)
uploads/

# Generated reports (regenerated on each scan — don't clutter the repo)
reports/*.json
reports/*.pdf

# Keep the reports folder itself tracked
!reports/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/
env/

# VS Code
.vscode/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Test firmware binaries (large, not source code)
*.bin
*.img
*.fw
!hardware/**/*.bin

# Arduino IDE build artifacts
*.hex
build/
